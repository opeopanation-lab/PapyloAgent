rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Pillar 2: Validation Blueprints
    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 512))
        && data.keys().hasAll(['uid', 'email'])
        && data.keys().size() <= 10;
    }

    function isValidTransmission(data) {
      return data.role in ['user', 'assistant']
        && data.content is string && data.content.size() <= 10000
        && data.timestamp == request.time
        && (!('modelId' in data) || (data.modelId is string && data.modelId.size() <= 128))
        && (!('attachments' in data) || (data.attachments is list && data.attachments.size() <= 5))
        && data.keys().hasAll(['role', 'content', 'timestamp'])
        && data.keys().size() <= 10;
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() <= 512
        && data.status in ['pending', 'completed', 'cancelled']
        && (!('priority' in data) || (data.priority in ['low', 'medium', 'high', 'critical']))
        && data.createdAt == request.time
        && (!('sourceTransmissionId' in data) || (data.sourceTransmissionId is string && data.sourceTransmissionId.size() <= 128))
        && data.keys().hasAll(['title', 'status', 'createdAt'])
        && data.keys().size() <= 10;
    }

    // -------------------------------------------------------------------------
    // Rules for Collections
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: Update Settings
        incoming().diff(existing()).affectedKeys().hasOnly(['settings', 'displayName', 'photoURL'])
      );

      match /transmissions/{transmissionId} {
        // Pillar 8: Secure List Queries
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        
        // Pillar 1 & 7: Relational Sync & Atomicity
        allow create: if isOwner(userId) 
          && isValidId(transmissionId) 
          && isValidTransmission(incoming())
          && exists(/databases/$(database)/documents/users/$(userId));
          
        // Pillar 2: Immutability
        allow update, delete: if false;
      }

      match /tasks/{taskId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(taskId) && isValidTask(incoming());
        allow update: if isOwner(userId) && isValidTask(incoming()) && (
          // Action: Update status or priority
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'priority', 'title'])
        );
        allow delete: if isOwner(userId);
      }
    }
  }
}
